{
  "name": "pinpoint",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "shared",
    "server",
    "dashboard",
    "extension",
    "e2e"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "npm run build --workspaces",
    "test": "vitest --run",
    "test:watch": "vitest",
    "test:coverage": "vitest --run --coverage",
    "typecheck": "tsc --noEmit --project tsconfig.json",
    "lint": "npm run lint --workspaces --if-present",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "fast-check": "^4.1.1",
    "jsdom": "^29.0.2",
    "typescript": "^5.8.3",
    "vitest": "^3.2.1",
    "zod": "^3.25.36"
  }
}
